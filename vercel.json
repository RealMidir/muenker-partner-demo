    { "source": "/fuehrungskraeftevermittlung/", "destination": "/ratgeber/fuehrungskraeftevermittlung/", "permanent": true },
    { "source": "/unternehmensberatung-duesseldorf", "destination": "/ratgeber/unternehmensberatung-duesseldorf/", "permanent": true },
