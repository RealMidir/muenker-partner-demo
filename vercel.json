    { "source": "/unternehmensberatung/vertriebsberatung", "destination": "/vertriebsberatung/", "permanent": true },
    { "source": "/unternehmensberatung/vertriebsberatung/", "destination": "/vertriebsberatung/", "permanent": true },

    { "source": "/personalberatung-duesseldorf", "destination": "/ratgeber/personalberatung-duesseldorf/", "permanent": true },
    { "source": "/personalberatung-duesseldorf/", "destination": "/ratgeber/personalberatung-duesseldorf/", "permanent": true },
    { "source": "/personalberatung-muenchen", "destination": "/ratgeber/personalberatung-muenchen/", "permanent": true },
    { "source": "/personalberatung-muenchen/", "destination": "/ratgeber/personalberatung-muenchen/", "permanent": true },
    { "source": "/recruiting-duesseldorf", "destination": "/ratgeber/recruiting-duesseldorf/", "permanent": true },
